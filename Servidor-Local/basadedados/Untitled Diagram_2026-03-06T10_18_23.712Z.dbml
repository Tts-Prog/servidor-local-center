enum estado_pendente_em_progresso_finalizado_cancelado_t {
	pendente
	em_progresso
	finalizado
	cancelado
}

enum estado_pendeste_aceito_recusado_t {
	pendeste
	aceito
	recusado
}

Table table_utilizadores [headercolor: #175e7a] {
	id varchar(255) [ pk, not null, unique ]
	nome varchar(50) [ not null ]
	numero_identificado varchar(100) [ not null ]
	data_nascimento date [ not null ]
	email varchar(255) [ not null ]
	telefone varchar(13)
	pais varchar(100) [ not null ]
	localidade varchar(100) [ not null ]
	password varchar(255)
	enabled boolean [ not null ]
	created_at datetime [ not null ]
	update_at datetime [ not null ]
}

Table table_prestadores [headercolor: #175e7a] {
	id varchar(255) [ pk, not null, unique ]
	taxa_urgencia decimal(10, 3)
	percentagem_desconto decimal(10, 3)
	minimo_descontoo decimal(10, 2)
	nif numeric [ not null ]
	profissao varchar(100) [ not null ]
	enable boolean [ not null ]
	criated_at datetime [ not null ]
	updated_at datetime [ not null ]
}

Table table_servico [headercolor: #175e7a] {
	id integer [ pk, increment, not null, unique ]
	nome varchar(50) [ not null ]
	discricao varchar(255)
	categoria varchar(20) [ not null ]
	enabled boolean [ not null ]
	creatd_at datetime [ not null ]
	update_at datetime [ not null ]
}

Table table_orcamente [headercolor: #175e7a] {
	id integer [ pk, increment, not null, unique ]
	total double [ not null ]
	id_utilizador varchar(255) [ not null ]
	enabled boolean [ not null ]
	created_at datetime [ not null ]
	updated_at datetime [ not null ]
}

Table table_prestacao_servico [headercolor: #175e7a] {
	id integer [ pk, increment, not null, unique ]
	designacao varchar(255) [ not null ]
	subtotal double [ not null ]
	hora_estimados integer
	id_prestador varchar(255) [ not null ]
	id_servico integer [ not null ]
	id_orcamento integer
	preco_hora double
	estado estado_pendente_em_progresso_finalizado_cancelado_t [ not null ]
	enabled boolean [ not null ]
	created_at datetime [ not null ]
	updated_at datetime [ not null ]
}

Table table_proposta [headercolor: #175e7a] {
	id integer [ pk, increment, not null, unique ]
	id_prestacao_servico integer [ not null ]
	preco_hora double [ not null ]
	hora_estimadas double [ not null ]
	estado estado_pendeste_aceito_recusado_t [ not null ]
	enabled boolean [ not null ]
	criated_at datetime [ not null ]
	updated_at datetime [ not null ]
}

Ref fk_table_orcamente_id_utilizador_table_utilizadores {
	table_orcamente.id_utilizador > table_utilizadores.id [ delete: no action, update: no action ]
}

Ref fk_table_prestadores_id_table_prestacao_servico {
	table_prestadores.id < table_prestacao_servico.id_prestador [ delete: no action, update: no action ]
}

Ref fk_table_prestacao_servico_id_servico_table_servico {
	table_prestacao_servico.id_servico > table_servico.id [ delete: no action, update: no action ]
}

Ref fk_table_prestacao_servico_id_orcamento_table_orcamente {
	table_prestacao_servico.id_orcamento > table_orcamente.id [ delete: no action, update: no action ]
}

Ref fk_table_prestacao_servico_id_table_proposta {
	table_prestacao_servico.id < table_proposta.id_prestacao_servico [ delete: no action, update: no action ]
}